{
  "expo": {
    "name": "San",
    "slug": "san-mes",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "san-mes",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#141414"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sanmes.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["audio"],
        "NSPhotoLibraryUsageDescription": "San uses your photo library so you can attach images to posts, comments, and chat messages, and so you can set a profile picture, banner, or chat background.",
        "NSPhotoLibraryAddUsageDescription": "San saves screenshots of posts to your photo library when you tap Save.",
        "NSCameraUsageDescription": "San uses the camera so you can take a photo to attach to a post."
      },
      "entitlements": {
        "com.apple.security.application-groups": ["group.com.sanmes.app"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.sanmes.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "./plugins/withFmtPatch",
      "@bacons/apple-targets",
      [
        "expo-alternate-app-icons",
        [
          { "name": "Classic", "ios": "./assets/app-icons/classic.png" },
          { "name": "Dark", "ios": "./assets/app-icons/dark.png" },
          { "name": "Blue", "ios": "./assets/app-icons/blue.png" },
          { "name": "Orange", "ios": "./assets/app-icons/orange.png" },
          { "name": "Mono", "ios": "./assets/app-icons/mono.png" },
          { "name": "Gradient", "ios": "./assets/app-icons/gradient.png" }
        ]
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9d37a5f0-54d8-4d17-8b7f-37ce6256ae06"
      }
    },
    "owner": "odserser",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9d37a5f0-54d8-4d17-8b7f-37ce6256ae06",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    }
  }
}
