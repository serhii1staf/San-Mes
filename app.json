{
  "expo": {
    "name": "San",
    "slug": "san-mes",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "san-mes",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "locales": {
      "en": "./locales/en.json",
      "ru": "./locales/ru.json"
    },
    "splash": {
      "backgroundColor": "#141414"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sanmes.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ],
        "NSPhotoLibraryUsageDescription": "San uses your photo library so you can attach images to posts, comments, and chat messages, and so you can set a profile picture, banner, or chat background.",
        "NSPhotoLibraryAddUsageDescription": "San saves screenshots of posts to your photo library when you tap Save.",
        "NSCameraUsageDescription": "San uses the camera so you can take a photo to attach to a post."
      },
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.sanmes.app"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFF8F0"
      },
      "package": "com.sanmes.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#141414",
          "image": "./assets/splash-transparent.png",
          "imageWidth": 1,
          "dark": {
            "backgroundColor": "#141414",
            "image": "./assets/splash-transparent.png",
            "imageWidth": 1
          }
        }
      ],
      "./plugins/withFmtPatch",
      "./plugins/withAndroidLintDisable",
      "@bacons/apple-targets",
      [
        "expo-alternate-app-icons",
        [
          {
            "name": "Style1",
            "ios": "./assets/app-icons/style1.png",
            "android": {
              "foregroundImage": "./assets/app-icons/style1.png",
              "backgroundColor": "#FFFFFF"
            }
          },
          {
            "name": "Style2",
            "ios": "./assets/app-icons/style2.png",
            "android": {
              "foregroundImage": "./assets/app-icons/style2.png",
              "backgroundColor": "#FFFFFF"
            }
          },
          {
            "name": "Style3",
            "ios": "./assets/app-icons/style3.png",
            "android": {
              "foregroundImage": "./assets/app-icons/style3.png",
              "backgroundColor": "#FFFFFF"
            }
          },
          {
            "name": "Style4",
            "ios": "./assets/app-icons/style4.png",
            "android": {
              "foregroundImage": "./assets/app-icons/style4.png",
              "backgroundColor": "#FFFFFF"
            }
          }
        ]
      ],
      [
        "@sentry/react-native/expo",
        {
          "url": "https://de.sentry.io/",
          "organization": "san-00",
          "project": "san-mes"
        }
      ],
      "expo-localization",
      "expo-notifications"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "9d37a5f0-54d8-4d17-8b7f-37ce6256ae06"
      }
    },
    "owner": "odserser",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/9d37a5f0-54d8-4d17-8b7f-37ce6256ae06",
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    }
  }
}
