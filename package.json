{
  "name": "san-mes",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest --passWithNoTests",
    "lint": "expo lint",
    "ts:check": "tsc --noEmit",
    "optimize:icons": "node scripts/optimize-pixel-icons.mjs",
    "optimize:previews": "node scripts/optimize-mini-app-previews.mjs",
    "postinstall": "node -e \"const fs=require('fs');['node_modules/react-native/ReactCommon/fmt/include/fmt/base.h'].forEach(p=>{if(fs.existsSync(p)){let c=fs.readFileSync(p,'utf8');if(c.includes('define FMT_USE_CONSTEVAL 1')){c=c.replace(/#  define FMT_USE_CONSTEVAL 1/g,'#  define FMT_USE_CONSTEVAL 0');fs.writeFileSync(p,c);console.log('Patched:',p)}}});console.log('postinstall: fmt patch check done')\"",
    "eas-build-post-install": "bash eas-build-post-install.sh"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.106.2",
    "ably": "^2.22.1",
    "aws4fetch": "^1.0.20",
    "expo": "~56.0.11",
    "expo-alternate-app-icons": "^8.0.0",
    "expo-asset": "~12.0.13",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.24",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-updates": "~29.0.18",
    "js-sha256": "^0.11.1",
    "obscenity": "0.4.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-context-menu-view": "^1.21.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.18.5",
    "react-native-mmkv": "^3.3.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-web": "^0.21.0",
    "react-native-web-webview": "^1.0.2",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "react-native-youtube-iframe": "^2.4.1",
    "sharp": "^0.33.5",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@babel/plugin-transform-class-properties": "^7.25.0",
    "@babel/plugin-transform-private-methods": "^7.25.0",
    "@babel/plugin-transform-private-property-in-object": "^7.25.0",
    "@bacons/apple-targets": "^4.0.7",
    "@types/jest": "^29.5.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "~54.0.0",
    "fast-check": "^4.8.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ]
  },
  "private": true
}
